%% qianji.scenario.id: deep_read
%% qianji.scenario.name: PAPER_DEEP_READ
%% qianji.scenario.description: canonical paper package -> deep read package
%% qianji.scenario.note: `qianji check` evaluates this bounded run-local surface; Codex should materialize staging patches here before merging into the persistent paper package.
%% qianji.scenario.topology: bounded_loop
%% qianji.scenario.workdir_root: runs/<run_id>
%% qianji.scenario.requires:
%%   - refs/paper.json
%%   - refs/topic.json
%% qianji.scenario.target_root: papers/<paper_id>
%% qianji.scenario.target_paths:
%%   - semantics/method_card.json
%%   - semantics/experiment_sheet.json
%%   - semantics/result_sheet.json
%%   - semantics/claim_ledger.jsonl
%%   - semantics/evidence_ledger.jsonl
%%   - semantics/limitation_sheet.json
%%   - notebook/critique_log.md
%%   - notebook/open_questions.jsonl
%%   - notebook/reading_journal.md
%%   - syntheses/deep_read.md
%%   - syntheses/methods_digest.md
%%   - syntheses/results_digest.md
%%   - syntheses/critique_memo.md
flowchart LR
  paper_package["research/paper"] --> load_paper_package["load_paper_package"]
  load_paper_package --> methods_extract["methods_extract"]
  methods_extract --> results_extract["results_extract"]
  results_extract --> claim_extract["claim_extract"]
  claim_extract --> evidence_ground["evidence_ground"]
  evidence_ground --> limitation_extract["limitation_extract"]
  limitation_extract --> critique["critique"]
  critique --> notebook_update["notebook_update"]
  notebook_update --> materialize_syntheses["materialize_syntheses"]
  materialize_syntheses --> deep_read_done["deep_read_done"]
  deep_read_done --> done_gate["done gate"]

  methods_extract -- fail --> diagnostics["diagnostics"]
  results_extract -- fail --> diagnostics
  claim_extract -- fail --> diagnostics
  evidence_ground -- fail --> diagnostics
  limitation_extract -- fail --> diagnostics
  critique -- fail --> diagnostics
  notebook_update -- fail --> diagnostics
  materialize_syntheses -- fail --> diagnostics
  diagnostics --> load_paper_package

